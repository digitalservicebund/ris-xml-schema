fileignoreconfig:
  - filename: README.md
    allowed_patterns:
      - secrets
      - Secrets
  - filename: LICENSE
    allowed_patterns:
      - "keys"
  - filename: SECURITY.md
    allowed_patterns:
      - "public key"
  - filename: xsd/akn/akomantoso30.xsd
    allowed_patterns:
      - keyword
      - passive
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - "key: "
scopeconfig:
  - scope: node
allowed_patterns:
  - uses:\ ([A-z0-9\-]+\/)*[A-z0-9\-]+@[a-fA-F0-9]{40}
  - "secrets: inherit"
  - passiv
  - passive
  - Passivzitierung
