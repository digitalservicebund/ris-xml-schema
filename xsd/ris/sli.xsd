      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="vorauflagen">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Vorauflagen
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element
