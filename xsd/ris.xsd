      <xs:element
        name="orientierungssatz"
        type="ris:orientierungssatz"
        minOccurs="0"
      />
      <xs:element
        name="sonstigerOrientierungssatz"
        type="ris:sonstigerOrientierungssatz"
        minOccurs="0"
      />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="entscheidungsnamen">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Namen einer Gerichtsentscheidung
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element
        name="entscheidungsname"
        type="ris:entscheidungsname"
        maxOccurs="unbounded"
      />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="entscheidungsname">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Name einer Gerichtsentscheidung
      </xs:documentation>
    </xs:annotation>
