  <xs:complexType name="periodikumTitel">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Titel des Periodikums
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="ris:stringWithDomainTerm" />
