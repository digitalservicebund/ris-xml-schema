<?xml version="1.0" encoding="UTF-8" ?>
<xs:schema
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:ris="http://rechtsinformationen.bund.de/schema/ris/0.1"
  elementFormDefault="qualified"
  targetNamespace="http://rechtsinformationen.bund.de/schema/ris/0.1"
>
  <xs:annotation>
    <xs:documentation xml:lang="de">
      Typen, die nur im Bereich selbstständige Literatur vorhanden sind.

      Diese sind nur in einer extra Datei um die Schema-Datein übersichtlicher zu haben.
    </xs:documentation>
  </xs:annotation>

  <xs:include schemaLocation="domain-term.xsd" />

  <xs:complexType name="gesamttitelAngaben">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Angaben zum Gesamttitel
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element
        name="gesamttitel"
        type="ris:gesamttitel"
        maxOccurs="unbounded"
      />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="gesamttitel">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Angabe zum Gesamttitel
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="titel" type="ris:gesamttitelTitel" />
      <xs:element name="bandbezeichnung" type="ris:bandbezeichnung" />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="gesamttitelTitel">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Titel des Gesamttitels
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="bandbezeichnung">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Bezeichnung des Bandes
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="titelkurzformen">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Kurzformen des Titels
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element
        name="titelkurzform"
        type="ris:titelkurzform"
        maxOccurs="unbounded"
      />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="titelkurzform">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Kurzform des Titels
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="ausgabe">
    <xs:annotation>
      <xs:documentation xml:lang="de">
