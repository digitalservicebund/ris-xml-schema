<?xml version="1.0" encoding="UTF-8" ?>
<xs:schema
  xmlns="http://MetadatenRechtsetzungsdokument.LegalDocML.de/1.9/"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  elementFormDefault="qualified"
  targetNamespace="http://MetadatenRechtsetzungsdokument.LegalDocML.de/1.9/"
  version="LegalDocML.de 1.9 (03.11.2025)"
>
  <!-- ********************************* Hinweis zur Lizensierung ********************************* -->
  <xs:annotation>
    <xs:appinfo>
      <copyright-hinweis
      >2025 Copyright © 2021–2025 Bundesministerium des Innern und für Heimat, 
Referat DG II 6, Maßnahmen Enterprise Resource Management und Elektronische Verwaltungsarbeit</copyright-hinweis>
      <lizenz
        url="https://creativecommons.org/licenses/by/3.0/legalcode.de"
        kurzbezeichnung="CC-BY-3.0"
        langbezeichnung="Creative Commons Namensnennung 3.0"
      />
      <autor
        organisation="Bundesministerium des Innern und für Heimat"
        referat="DG II 6"
        organisatorischer-rahmen="Maßnahmen Enterprise Resource Management und Elektronische Verwaltungsarbeit"
      />
    </xs:appinfo>
  </xs:annotation>
  <!-- ******************************************************************************************** -->
  <xs:element name="legalDocML.de_metadaten">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="fna" type="xs:token" default="nicht-vorhanden">
          <xs:annotation>
            <xs:documentation
            >Der Fundstellennachweis A (FNA) weist die Fundstellen der im Bundesgesetzblatt oder Bundesanzeiger veröffentlichten geltenden Gesetze und Rechtsverordnungen der Bundesrepublik Deutschland nach. In der Entwurfsfassung ist das Literal "nicht-vorhanden" zu verwenden.</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="gesta" type="xs:token" default="nicht-vorhanden">
          <xs:annotation>
            <xs:documentation
            >Die GESTA-Ordnungsnummer ist eine von der Parlamentsdokumentation des Bundestages vergebene Kennzeichnung eines Gesetzgebungsverfahrens. Falls sie unbekannt ist, ist das Literal 'nicht-vorhanden' anzugeben.</xs:documentation>
          </xs:annotation>
        </xs:element>
        <xs:element name="gegenstandlos" minOccurs="0">
          <xs:complexType>
            <xs:attribute name="seit" type="xs:date" use="optional">
              <xs:annotation>
                <xs:documentation
                >Kennzeichnung, wann das vorliegende Rechtsetzungsdokument als gegenstandslos deklariert wurde.</xs:documentation>
              </xs:annotation>
            </xs:attribute>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:simpleType name="institution" final="restriction">
    <xs:restriction base="xs:string">
      <xs:enumeration value="bundesregierung" />
      <xs:enumeration value="bundestag" />
      <xs:enumeration value="bundesrat" />
      <xs:enumeration value="bundespräsident" />
      <xs:enumeration value="bundeskanzler" />
      <xs:enumeration value="nicht-vorhanden" />
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="mindestens-ein-zeichen">
    <xs:restriction base="xs:token">
      <xs:minLength value="1" />
    </xs:restriction>
  </xs:simpleType>
</xs:schema>
