<?xml version="1.0" encoding="UTF-8" ?>
<xs:schema
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:akn="http://docs.oasis-open.org/legaldocml/ns/akn/3.0"
  xmlns:ris="http://rechtsinformationen.bund.de/schema/ris/0.1/"
  elementFormDefault="qualified"
  targetNamespace="http://rechtsinformationen.bund.de/schema/ris/0.1/"
>
  <xs:import
    namespace="http://www.w3.org/XML/1998/namespace"
    schemaLocation="./akn/xml.xsd"
  />
  <xs:import
    namespace="http://docs.oasis-open.org/legaldocml/ns/akn/3.0"
    schemaLocation="./akn/akomantoso30.xsd"
  />

  <xs:redefine schemaLocation="ris.xsd">
    <xs:complexType name="meta">
      <xs:complexContent>
        <xs:restriction base="ris:meta">
          <xs:sequence>
            <xs:element ref="ris:dokumenttyp" />
            <xs:element ref="ris:gericht" />
            <xs:element ref="ris:fehlerhafteGerichte" minOccurs="0" />
            <xs:element ref="ris:regionen" />
            <xs:element ref="ris:dokumentationsstelle" minOccurs="0" />
            <xs:element ref="ris:aktenzeichenListe" />
            <xs:element
              ref="ris:datenDerMuendlichenVerhandlung"
              minOccurs="0"
            />
            <xs:element ref="ris:abweichendeDaten" minOccurs="0" />
            <xs:element ref="ris:abweichendeDokumentnummern" minOccurs="0" />
            <xs:element ref="ris:abweichendeEclis" minOccurs="0" />
            <xs:element ref="ris:sachgebiete" minOccurs="0" />
            <xs:element ref="ris:rechtskraft" />
            <xs:element ref="ris:definitionen" minOccurs="0" />
            <xs:element ref="ris:tarifvertraege" minOccurs="0" />
            <xs:element ref="ris:quellen" minOccurs="0" />
            <xs:element ref="ris:streitjahre" minOccurs="0" />
            <xs:element ref="ris:berufsbilder" minOccurs="0" />
            <xs:element ref="ris:kuendigungsgruende" minOccurs="0" />
            <xs:element ref="ris:gesetzgebungsauftrag" minOccurs="0" />
            <xs:element ref="ris:herkunftslaender" minOccurs="0" />
            <xs:element ref="ris:vorabdokument" minOccurs="0" />
          </xs:sequence>
        </xs:restriction>
      </xs:complexContent>
    </xs:complexType>
  </xs:redefine>
</xs:schema>
