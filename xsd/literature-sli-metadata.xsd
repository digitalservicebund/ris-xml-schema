<?xml version="1.0" encoding="UTF-8" ?>
<xs:schema
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:akn="http://docs.oasis-open.org/legaldocml/ns/akn/3.0"
  xmlns:ris="http://rechtsinformationen.bund.de/schema/ris/0.1/"
  elementFormDefault="qualified"
  targetNamespace="http://rechtsinformationen.bund.de/schema/ris/0.1/"
>
  <xs:import
    namespace="http://www.w3.org/XML/1998/namespace"
    schemaLocation="./akn/xml.xsd"
  />
  <xs:import
    namespace="http://docs.oasis-open.org/legaldocml/ns/akn/3.0"
    schemaLocation="./akn/akomantoso30.xsd"
  />

  <xs:redefine schemaLocation="ris.xsd">
    <xs:complexType name="meta">
      <xs:complexContent>
        <xs:restriction base="ris:meta">
          <xs:sequence>
            <xs:element ref="ris:dokumenttypen" />
            <xs:element ref="ris:sachgebiete" minOccurs="0" />
            <xs:element ref="ris:veroeffentlichungsJahre" />
            <xs:element ref="ris:gliederung" minOccurs="0" />
            <xs:element ref="ris:gesamttitelAngaben" minOccurs="0" />
            <xs:element ref="ris:regionen" minOccurs="0" />
            <xs:element ref="ris:titelkurzformen" minOccurs="0" />
            <xs:element ref="ris:ausgabe" minOccurs="0" />
            <xs:element ref="ris:kollation" minOccurs="0" />
            <xs:element ref="ris:besitznachweise" minOccurs="0" />
            <xs:element ref="ris:teilbaende" minOccurs="0" />
            <xs:element ref="ris:bibliothekarischeVerweisungen" minOccurs="0" />
            <xs:element ref="ris:problemkreise" minOccurs="0" />
            <xs:element ref="ris:sonstigerSachtitelListe" minOccurs="0" />
            <xs:element ref="ris:vorauflagen" minOccurs="0" />
            <xs:element ref="ris:dubletteToleriert" minOccurs="0"/>
          </xs:sequence>
        </xs:restriction>
      </xs:complexContent>
    </xs:complexType>
  </xs:redefine>
</xs:schema>
