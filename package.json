{
  "type": "module",
  "scripts": {
    "format:check": "prettier --check .",
    "format:fix": "prettier --write --ignore-unknown .",
    "style:check": "npm run format:check",
    "style:fix": "npm run format:fix",
    "test": "npm run test:caselaw:decision && npm run test:caselaw:pending-proceeding",
    "test:caselaw:decision": "xmllint --noout --schema xsd/caselaw-decision.xsd samples/caselaw/decision/*.xml",
    "test:caselaw:pending-proceeding": "xmllint --noout --schema xsd/caselaw-pending-proceeding.xsd samples/caselaw/pending-proceeding/*.xml",
    "test:literature:sli": "xmllint --noout --schema xsd/literature-sli.xsd samples/literature/sli/*.xml",
    "test:literature:uli": "xmllint --noout --schema xsd/literature-uli.xsd samples/literature/uli/*.xml",
    "test:watch": "watch \"npm run test\" --wait=2"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "prettier": "^3.8.1",
    "watch": "^1.0.2"
  }
}
