<?xml version="1.0" encoding="UTF-8" ?>
<xs:schema
  xmlns="http://MetadatenSonstigerVeroeffentlichungstext.LegalDocML.de/1.9/"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  elementFormDefault="qualified"
  targetNamespace="http://MetadatenSonstigerVeroeffentlichungstext.LegalDocML.de/1.9/"
