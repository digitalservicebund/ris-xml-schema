{
  "type": "module",
  "scripts": {
    "format:check": "prettier --check .",
    "format:fix": "prettier --write --ignore-unknown .",
    "style:check": "npm run format:check",
    "style:fix": "npm run format:fix",
    "test": "npm run test:caselaw:decision && npm run test:caselaw:anhaengiges-verfahren",
    "test:caselaw:decision": "xmllint --noout --schema xsd/caselaw.xsd samples/caselaw/decision_*.xml",
    "test:caselaw:anhaengiges-verfahren": "xmllint --noout --schema xsd/caselaw-anhaengiges-verfahren.xsd samples/caselaw/pending_proceeding_*.xml",
    "test:watch": "watch \"npm run test\" --wait=2"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "prettier": "^3.8.1",
    "watch": "^1.0.2"
  }
}
