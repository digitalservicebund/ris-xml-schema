  </xs:complexType>

  <xs:complexType name="periodikumUntertitel">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Untertitel des Periodikums
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="ris:stringWithDomainTerm" />
