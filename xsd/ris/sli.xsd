  <xs:complexType name="kollation">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Kollation
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="umfangsangabe" type="ris:umfangsangabe" />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
