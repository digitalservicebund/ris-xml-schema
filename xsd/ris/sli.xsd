      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="besitznachweise">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Besitznachweise
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element
        name="besitznachweis"
        type="ris:besitznachweis"
        maxOccurs="unbounded"
      />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="besitznachweis">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Besitznachweis
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="institution" type="ris:institution" />
      <xs:element name="signatur" type="ris:signatur" minOccurs="0" />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="institution">
    <xs:annotation>
      <xs:documentation xml:lang="de">
