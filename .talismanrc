fileignoreconfig:
  - filename: README.md
    allowed_patterns:
      - secrets
      - Secrets
  - filename: LICENSE
    allowed_patterns:
      - "keys"
  - filename: SECURITY.md
    allowed_patterns:
      - "public key"
  - filename: xsd/akn/akomantoso30.xsd
    allowed_patterns:
      - keyword
      - passive
  - filename: .github/workflows/pipeline.yml
    allowed_patterns:
      - "key: "
  - filename: xsd/ldml/legalDocML.de.sch
    checksum: 797caf4ce0f19a869d2c1c2502e42e5ca0ca8acdaafb856b3d11be15cd2e2cec
  - filename: xsd/ldml/legalDocML.de-baukasten.xsd
    checksum: dc06d5dc76554eeff95b693eb77eb7a11a8de8b68ac13c5da7c9adbd6b1e2bbd
scopeconfig:
  - scope: node
allowed_patterns:
  - uses:\ ([A-z0-9\-]+\/)*[A-z0-9\-]+@[a-fA-F0-9]{40}
  - "secrets: inherit"
