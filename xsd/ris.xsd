  <xs:complexType name="periodikum">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Periodikum in dem die Fundstelle gefunden werden kann
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="abkuerzung" type="ris:periodikumAbkuerzung" />
      <xs:element name="periodikumTyp" type="ris:periodikumTyp" minOccurs="0" />
      <xs:element name="titel" type="ris:titel" />
      <xs:element
        name="untertitel"
        type="ris:periodikumUntertitel"
        minOccurs="0"
      />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
