    <xs:annotation>
      <xs:documentation xml:lang="de">
        Art der Fundstelle
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="ris:fundstellenTypValue">
        <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:simpleType name="fundstellenTypValue">
    <xs:restriction base="xs:string">
      <xs:enumeration value="nichtamtlich" />
      <xs:enumeration value="amtlich" />
    </xs:restriction>
