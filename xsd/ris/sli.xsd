    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="teilbaende">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Teilbände
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element name="teilband" type="ris:teilband" maxOccurs="unbounded" />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="teilband">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        Teilband
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:string">
        <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
      </xs:extension>
    </xs:simpleContent>
  </xs:complexType>

  <xs:complexType name="bibliothekarischeVerweisungen">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        bibliothekarische Verweisungen
      </xs:documentation>
    </xs:annotation>
    <xs:sequence>
      <xs:element
        name="bibliothekarischeVerweisung"
        type="ris:bibliothekarischeVerweisung"
        maxOccurs="unbounded"
      />
    </xs:sequence>
    <xs:attribute name="domainTerm" type="ris:domainTerm" use="required" />
  </xs:complexType>

  <xs:complexType name="bibliothekarischeVerweisung">
    <xs:annotation>
      <xs:documentation xml:lang="de">
        bibliothekarische Verweisung
      </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="xs:string">
